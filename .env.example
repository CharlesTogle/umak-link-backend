# Server Configuration
PORT=8080
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug

# CORS
CORS_ORIGIN=*

# Supabase (server-only - NEVER expose to clients)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# Authentication
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
ALLOWED_EMAIL_DOMAIN=umak.edu.ph
JWT_SECRET=generate-a-strong-random-secret-key-here
JWT_EXPIRY=7d

# AI Services
GEMINI_API_KEY=your-gemini-api-key

# Storage
SUPABASE_STORAGE_URL=https://your-project.supabase.co/storage/v1
ITEMS_BUCKET=items
PROFILE_PICTURES_BUCKET=profilePictures

# Firebase (for push notifications)
# Paste the entire service account JSON as a single-line string
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project",...}

# System Token (for scheduled jobs/cron)
SYSTEM_TOKEN=generate-a-strong-system-token-for-background-jobs
