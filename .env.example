# Server
PORT=8080
HOST=0.0.0.0
NODE_ENV=development
LOG_LEVEL=debug
# Comma-separated list of allowed frontend URLs for CORS
# Development: include both localhost variants
# Production: include your deployed frontend URL(s)
ALLOWED_ORIGINS=http://localhost:3000,http://127.0.0.1:3000,http://localhost:5173,http://127.0.0.1:5173

# Supabase
SUPABASE_URL=link
SUPABASE_SERVICE_ROLE_KEY=secret

# Authentication
JWT_SECRET=secret
JWT_EXPIRY=7d
# Must be the same value as frontend VITE_GOOGLE_CLIENT_ID
GOOGLE_CLIENT_ID=your-client-id.apps.googleusercontent.com
ALLOWED_EMAIL_DOMAIN=hihi

# Google Gemini AI
GEMINI_API_KEY=your-gemini-api-key

# Firebase Push Notifications
# Get this from Firebase Console > Project Settings > Service Accounts > Generate New Private Key
# Must be a single-line JSON string with escaped quotes and newlines
# Example: FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"your-project","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...@...iam.gserviceaccount.com","client_id":"...","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token","auth_provider_x509_cert_url":"https://www.googleapis.com/oauth2/v1/certs","client_x509_cert_url":"..."}
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"..."}

# System Jobs
SYSTEM_TOKEN=your-system-token
